<UserControl x:Class="YMM4.GeminiTTS.Plugin.Settings.GeminiTtsSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:YMM4.GeminiTTS.Plugin.Settings"
             d:DataContext="{d:DesignInstance Type=local:GeminiTtsSettings}"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="700">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <Expander Header="Google Cloud Text-to-Speech 接続設定" IsExpanded="True">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,4"
                               VerticalAlignment="Center"
                               Text="Service Account JSON"/>
                    <TextBox  Grid.Row="0" Grid.Column="1" Margin="0,0,4,4"
                              Text="{Binding ServiceAccountJsonPath, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button   Grid.Row="0" Grid.Column="2" Margin="0,0,0,4"
                              Content="参照..." Padding="8,2"
                              Click="BrowseJsonButton_Click"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,8,4"
                               VerticalAlignment="Center"
                               Text="言語コード"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,4,4,4"
                               Text="{Binding LanguageCode, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,8,4"
                               VerticalAlignment="Center"
                               Text="サンプルレート (Hz)"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,4,4,4"
                               Text="{Binding SampleRateHertz, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,4,8,4"
                               VerticalAlignment="Center"
                               Text="デフォルト Voice"/>
                    <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,4,4,4"
                               Text="{Binding DefaultVoiceName, UpdateSourceTrigger=PropertyChanged}"
                               ToolTip="30 voice のいずれか (例: Kore / Zephyr / Puck)"/>
                </Grid>
            </Expander>

            <Expander Header="スタイルプロンプト (全発話の前置指示)" IsExpanded="True" Margin="0,8,0,0">
                <Grid Margin="8">
                    <TextBox AcceptsReturn="True" TextWrapping="Wrap"
                             Height="120"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding DefaultStylePrompt, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Expander>

            <Expander Header="動作確認" IsExpanded="False" Margin="0,8,0,0">
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="設定した認証情報・Voice でテスト合成を行い、既定のテンポラリフォルダーに WAV を書き出します。"/>
                    <Button Content="テスト合成を実行" HorizontalAlignment="Left" Padding="12,4"
                            Click="TestSynthesisButton_Click"/>
                    <TextBlock Name="TestResultText" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
